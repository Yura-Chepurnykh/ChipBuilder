{
  "layerRules": [
    { "layer": "active",  "minWidth": 3, "minSpace": 3, "minArea": 9 },
    { "layer": "poly",    "minWidth": 2, "minSpace": 2, "minArea": 4 },
    { "layer": "nwell",   "minWidth": 4, "minSpace": 4, "minArea": 16 },
    { "layer": "pwell",   "minWidth": 4, "minSpace": 4, "minArea": 16 },
    { "layer": "metal1",  "minWidth": 3, "minSpace": 3, "minArea": 9 },
    { "layer": "via",     "minWidth": 2, "minSpace": 2, "minArea": 4 },
    { "layer": "contact", "minWidth": 2, "minSpace": 2, "minArea": 4 }
