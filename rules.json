{
  "_meta": {
    "process": "TSMC 180nm (educational approximation)",
    "lambda": "0.09um",
    "layers": ["active", "poly", "nwell", "pwell", "metal1", "via", "contact"],
    "unary_rules": ["min_width", "min_space"],
    "binary_rules": ["min_space", "enclosure", "overlap"],
    "note": "contact = poly/active → metal1 | via = metal1 → metal2 (no metal2 layer here, via rules are enclosure-only)"
  },

  "layers": {

    "active": {
      "min_width":  4,
      "min_space":  3
    },

    "poly": {
      "min_width":  2,
      "min_space":  2
    },

    "nwell": {
      "min_width":  12,
      "min_space":  18
    },

    "pwell": {
      "min_width":  12,
      "min_space":  18
    },

    "metal1": {
      "min_width":  4,
      "min_space":  4
    },

    "contact": {
      "min_width":  2,
      "min_space":  2
    },

    "via": {
      "min_width":  2,
      "min_space":  3
    }

  },

  "binary_rules": {

    "min_space": [
      {
        "layers": ["nwell", "pwell"],
        "value": 0,
        "comment": "nwell and pwell must not overlap; 0 means they can touch but not cross"
      },
      {
        "layers": ["poly", "active"],
        "value": 1,
        "comment": "poly end to active edge spacing (field poly)"
      }
    ],

    "enclosure": [
      {
        "outer": "active",
        "inner": "contact",
        "value": 1,
        "comment": "active must surround contact by at least 1λ on all sides"
      },
      {
        "outer": "poly",
        "inner": "contact",
        "value": 1,
        "comment": "poly contact: poly must surround contact by 1λ"
      },
      {
        "outer": "metal1",
        "inner": "contact",
        "value": 1,
        "comment": "metal1 must surround contact by 1λ on all sides"
      },
      {
        "outer": "metal1",
        "inner": "via",
        "value": 1,
        "comment": "metal1 must surround via by 1λ on all sides"
      },
      {
        "outer": "nwell",
        "inner": "active",
        "value": 6,
        "comment": "nwell must surround p+ active (pmos) by 6λ"
      },
      {
        "outer": "pwell",
        "inner": "active",
        "value": 6,
        "comment": "pwell must surround n+ active (nmos) by 6λ"
      }
    ],

    "overlap": [
      {
        "layers": ["poly", "active"],
        "value": 2,
        "comment": "poly must extend over active by 2λ on each side (gate extension)"
      },
      {
        "layers": ["active", "nwell"],
        "value": 0,
        "comment": "pmos active must be inside nwell (overlap ≥ 0 enforced via enclosure above)"
      }
    ]

  }
}